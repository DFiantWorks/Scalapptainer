#!/bin/sh
# Vendored by Scalapptainer: a minimal, dependency-light rpm2cpio.
#
# Extracts and decompresses the cpio payload from an RPM. Payload compression is
# detected from magic bytes (so this does not depend on the `file` command).
# Requires: od, dd, and the relevant decompressor (gzip/xz/zstd/bzip2) for the
# RPM's payload. Debian/Ubuntu never ship rpm2cpio, which is why this is bundled.
#
# Usage: rpm2cpio PACKAGE.rpm   (or `-`/no arg to read the RPM from stdin)
set -eu

pkg="${1:--}"
if [ "$pkg" = "-" ]; then
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  cat > "$tmp"
  pkg="$tmp"
elif [ ! -e "$pkg" ]; then
  echo "rpm2cpio: cannot find package '$pkg'" >&2
  exit 1
fi

# RPM lead is 96 bytes; each header section starts with an 8-byte intro, then
# index-entry count (il) and store size (dl) as 32-bit big-endian integers.
read_hdr_sizes() {
  off=$1
  set -- $(od -j "$off" -N 8 -A n -t u1 "$pkg")
  il=$(( $1 * 16777216 + $2 * 65536 + $3 * 256 + $4 ))
  dl=$(( $5 * 16777216 + $6 * 65536 + $7 * 256 + $8 ))
}

o=$((96 + 8))                       # past lead + signature intro
read_hdr_sizes "$o"
sigsize=$(( il * 16 + dl ))
# signature header is padded to an 8-byte boundary, then the main header intro
o=$(( o + 8 + sigsize + (8 - (sigsize % 8)) % 8 + 8 ))
read_hdr_sizes "$o"
hdrsize=$(( il * 16 + dl ))
o=$(( o + 8 + hdrsize ))            # start of the compressed payload

magic=$(dd if="$pkg" bs=1 skip="$o" count=6 2>/dev/null | od -An -t x1 | tr -d ' \n')
extract="dd if=$pkg bs=$o skip=1"

case "$magic" in
  1f8b*)        $extract 2>/dev/null | gzip -dc ;;
  fd377a585a00) $extract 2>/dev/null | xz -dc ;;
  28b52ffd*)    $extract 2>/dev/null | zstd -dc ;;
  425a68*)      $extract 2>/dev/null | bzip2 -dc ;;
  5d0000*)      $extract 2>/dev/null | xz -dc --format=lzma ;;
  *)            $extract 2>/dev/null ;;   # assume an uncompressed cpio payload
esac
